<template>
  <Grid
    :data-items="filteredData"
    :columns="columns"
    :column-menu="true"
    :filterable="true"
  >
    <template v-slot:dateColumnMenu="{ props }">
      <CustomDateMenu
        field="birthDate"
        :on-close-menu="props.onCloseMenu"
        @filterchange="onFilterChange"
        @clearfilter="onClearFilter"
      />
    </template>
  </Grid>
</template>

<script setup>
import { ref, computed }  from 'vue';
import { Grid }           from '@progress/kendo-vue-grid';
import { filterBy }       from '@progress/kendo-data-query';
import CustomDateMenu     from './CustomDateMenu.vue';

// ── Static data ───────────────────────────────────────────────────────────────

const rawData = [
  { name: 'Alice', birthDate: new Date('1990-01-15') },
  { name: 'Bob',   birthDate: new Date('1985-07-22') },
  { name: 'Carol', birthDate: new Date('1992-11-03') },
  { name: 'David', birthDate: new Date('1988-03-30') },
  { name: 'Eve',   birthDate: new Date('1995-06-18') },
];

const columns = [
  {
    field: 'name',
    title: 'Name',
  },
  {
    field:      'birthDate',
    title:      'Birth Date',
    format:     '{0:MM/dd/yyyy}',
    filter:     'date',
    sortable:   false,
    columnMenu: 'dateColumnMenu',
  },
];

// ── Reactive state ────────────────────────────────────────────────────────────

const activeFilter = ref(null);

// ── Computed ──────────────────────────────────────────────────────────────────

const filteredData = computed(() =>
  activeFilter.value ? filterBy(rawData, activeFilter.value) : rawData
);

// ── Handlers ──────────────────────────────────────────────────────────────────

function onFilterChange(filter) {
  activeFilter.value = filter;
}

function onClearFilter() {
  activeFilter.value = null;
}
</script>
