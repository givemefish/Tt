<template>
  <div class="custom-date-menu">
    <h4>Filter by Date</h4>

    <div class="filter-row">
      <label>Operator</label>
      <DropDownList
        :data-items="operatorOptions"
        :text-field="'text'"
        :data-item-key="'value'"
        :value="selectedOperator"
        @change="e => selectedOperator = e.value"
      />
    </div>

    <div class="filter-row">
      <label>Date</label>
      <DatePicker
        :value="dateValue"
        :format="'MM/dd/yyyy'"
        @change="e => dateValue = e.value"
      />
    </div>

    <div class="button-row">
      <button class="k-button k-primary" @click="applyFilter">Filter</button>
      <button class="k-button"           @click="clearFilter">Clear</button>
    </div>
  </div>
</template>

<script setup>
import { ref } from 'vue';
import { DropDownList } from '@progress/kendo-vue-dropdowns';
import { DatePicker }   from '@progress/kendo-vue-dateinputs';

// ── Props & Emits ─────────────────────────────────────────────────────────────

const props = defineProps({
  field: {
    type:    String,
    required: true,
  },
  onCloseMenu: {
    type:    Function,
    default: null,
  },
});

const emit = defineEmits(['filterchange', 'clearfilter']);

// ── Static data ───────────────────────────────────────────────────────────────

const operatorOptions = [
  { text: 'On or After',  value: 'gte' },
  { text: 'On or Before', value: 'lte' },
  { text: 'Equals',       value: 'eq'  },
  { text: 'Not Equals',   value: 'neq' },
  { text: 'After',        value: 'gt'  },
  { text: 'Before',       value: 'lt'  },
];

// ── Reactive state ────────────────────────────────────────────────────────────

const selectedOperator = ref(operatorOptions[0]);
const dateValue        = ref(null);

// ── Methods ───────────────────────────────────────────────────────────────────

function applyFilter() {
  if (!dateValue.value) return;

  emit('filterchange', {
    logic: 'and',
    filters: [
      {
        field:    props.field,
        operator: selectedOperator.value.value,
        value:    dateValue.value,
      },
    ],
  });

  props.onCloseMenu?.();
}

function clearFilter() {
  selectedOperator.value = operatorOptions[0];
  dateValue.value        = null;

  emit('clearfilter');
  props.onCloseMenu?.();
}
</script>

