<template>
  <div class="date-filter-wrap">
    <div class="filter-row">
      <label class="filter-label">起始日期</label>
      <k-date-picker
        v-model="startDate"
        :placeholder="'選擇起始日期'"
        :format="'yyyy/MM/dd'"
        style="width: 100%"
      />
    </div>
    <div class="filter-row">
      <label class="filter-label">結束日期</label>
      <k-date-picker
        v-model="endDate"
        :placeholder="'選擇結束日期'"
        :format="'yyyy/MM/dd'"
        style="width: 100%"
      />
    </div>
    <div class="filter-actions">
      <button class="btn-filter-apply" @click="applyFilter">套用</button>
      <button class="btn-filter-clear" @click="clearFilter">清除</button>
    </div>
  </div>
</template>

<script>
import { DatePicker as KDatePicker } from "@progress/kendo-vue-dateinputs";

export default {
  name: "DateRangeFilter",
  components: { KDatePicker },
  props: {
    field: { type: String, required: true },
    currentFilter: { type: Object, default: null },
  },
  emits: ["filterchange"],
  data() {
    return {
      startDate: null,
      endDate: null,
    };
  },
  methods: {
    applyFilter() {
      const filters = [];
      if (this.startDate) {
        filters.push({ field: this.field, operator: "gte", value: this.startDate });
      }
      if (this.endDate) {
        // 結束日期包含當天: 設為當天 23:59:59
        const endOfDay = new Date(this.endDate);
        endOfDay.setHours(23, 59, 59, 999);
        filters.push({ field: this.field, operator: "lte", value: endOfDay });
      }
      this.$emit("filterchange", filters);
    },
    clearFilter() {
      this.startDate = null;
      this.endDate = null;
      this.$emit("filterchange", []);
    },
  },
};
</script>

